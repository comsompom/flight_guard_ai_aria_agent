APP_NAME=FlightGuard Agent API
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000

# Airia Pipeline Execution API (from Agent Settings > Interfaces > API)
# Use the exact API Url and create an API key in Airia; set X-API-KEY in requests.
AIRIA_API_URL=https://api.airia.ai/v2/PipelineExecution/YOUR_PIPELINE_GUID
AIRIA_API_KEY=
AIRIA_TIMEOUT_SECONDS=20

# Optional: set OPENWEATHER_API_KEY to use OpenWeather instead of Open-Meteo (no key needed).
# Weather and elevation use Open-Meteo + Open-Elevation by default (no registration).
OPENWEATHER_API_KEY=
OPEN_TOPO_BASE_URL=https://api.opentopodata.org/v1
